# ─── Database ─────────────────────────────────────────────
# Neon serverless PostgreSQL connection string (production)
# Local Docker PostgreSQL (development): postgresql://postgres:postgres@localhost:5432/fitfam
DATABASE_URL=

# ─── Clerk Authentication ─────────────────────────────────
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# ─── File Storage ─────────────────────────────────────────
# UploadThing (production)
UPLOADTHING_TOKEN=

